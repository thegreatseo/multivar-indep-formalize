        rw [ show ( Real.sqrt ( 2 + d ) ) ^ 4 = ( Real.sqrt ( 2 + d ) ^ 2 ) ^ 2 by ring, show ( Real.sqrt ( 1 + d ) ) ^ 4 = ( Real.sqrt ( 1 + d ) ^ 2 ) ^ 2 by ring, Real.sq_sqrt <| by positivity, Real.sq_sqrt <| by positivity ] ; norm_num [ pow_three, hw1, hx1, hy1, hw2, hx2, hy2 ] ; ring;
