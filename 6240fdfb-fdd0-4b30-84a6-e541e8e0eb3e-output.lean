/-
Homogenization of A_{d+1}.
-/
def h_homog (d : ℕ) (w x y : ℝ) : ℝ :=
  (d + 1 : ℝ) * d * w ^ (d - 1) * x * y + (d + 1 : ℝ) * w ^ d * (x + y) + w ^ (d + 1)

/-
Relation between h_homog and A_d.
-/
lemma h_homog_eq_Ad (d : ℕ) (w x y : ℝ) (hw : w > 0) :
    h_homog d w x y = w ^ (d + 1) * A_d (d + 1) (x / w) (y / w) := by
      unfold h_homog A_d; ring;
      field_simp;
      cases d <;> norm_num [ pow_succ' ] ; ring;
      ring

