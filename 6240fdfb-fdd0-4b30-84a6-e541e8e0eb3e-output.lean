-/
lemma Sd_implies_h_homog_new (d : ℕ) (hd : d ≥ 1) (a : ℝ × ℝ × ℝ) (ha : a ∈ S_d d) :
    ∀ w x y, w ≥ 0 → x ≥ 0 → y ≥ 0 →
    a.1 * w + a.2.1 * x + a.2.2 * y ≥ (h_homog d w x y) ^ (1 / ((d : ℝ) + 1)) := by
      intro w x y hw hx hy;
      by_cases hw0 : w = 0;
      · -- By continuity of $h_homog$, we can take the limit as $w \to 0$.
        have h_cont : Filter.Tendsto (fun w => a.1 * w + a.2.1 * x + a.2.2 * y - h_homog d w x y ^ (1 / (d + 1 : ℝ))) (nhdsWithin 0 (Set.Ioi 0)) (nhds (a.2.1 * x + a.2.2 * y - (h_homog d 0 x y) ^ (1 / (d + 1 : ℝ)))) := by
          refine' Filter.Tendsto.sub _ _;
          · exact tendsto_nhdsWithin_of_tendsto_nhds ( Continuous.tendsto' ( by continuity ) _ _ ( by norm_num ) );
          · refine' Filter.Tendsto.rpow _ _ _;
            · exact Continuous.continuousWithinAt ( by unfold h_homog; continuity );
            · exact tendsto_const_nhds;
            · exact Or.inr ( by positivity );
        have h_cont : ∀ᶠ w in nhdsWithin 0 (Set.Ioi 0), a.1 * w + a.2.1 * x + a.2.2 * y - (h_homog d w x y) ^ (1 / (d + 1 : ℝ)) ≥ 0 := by
          filter_upwards [ self_mem_nhdsWithin ] with w hw;
