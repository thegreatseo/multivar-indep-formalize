        have := le_of_tendsto_of_tendsto tendsto_const_nhds ‹_› h_cont; aesop;
      · convert Sd_implies_h_homog_pos_w_new d hd a ha w x y ( lt_of_le_of_ne hw ( Ne.symm hw0 ) ) hx hy using 1

