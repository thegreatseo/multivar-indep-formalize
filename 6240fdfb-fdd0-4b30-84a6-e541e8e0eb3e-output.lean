          · exact Filter.Tendsto.mul ( tendsto_const_nhds.mul ( Filter.Tendsto.pow ( tendsto_one_div_add_atTop_nhds_zero_nat ) _ ) ) tendsto_const_nhds;
          · exact Filter.Tendsto.pow ( tendsto_one_div_add_atTop_nhds_zero_nat ) _;
