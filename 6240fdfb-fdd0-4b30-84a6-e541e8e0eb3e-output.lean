/-
Forward direction of S_d characterization for w > 0.
-/
lemma Sd_implies_h_homog_pos_w (d : ℕ) (hd : d ≥ 1) (a : ℝ × ℝ × ℝ) (ha : a ∈ S_d d)
    (w x y : ℝ) (hw : w > 0) (hx : x ≥ 0) (hy : y ≥ 0) :
    a.1 * w + a.2.1 * x + a.2.2 * y ≥ (h_homog d w x y) ^ (1 / ((d : ℝ) + 1)) := by
      -- Apply the definition of $S_d$ to obtain the inequality.
      have h_ineq : a.1 + a.2.1 * (x / w) + a.2.2 * (y / w) ≥ A_d (d + 1) (x / w) (y / w) ^ (1 / (d + 1 : ℝ)) := by
        exact ha.2.2.2 _ _ ( div_nonneg hx hw.le ) ( div_nonneg hy hw.le );
      -- Substitute the expression for $h_homog$ into the inequality.
      have h_subst : (h_homog d w x y) = w ^ (d + 1) * A_d (d + 1) (x / w) (y / w) := by
        exact h_homog_eq_Ad d w x y hw;
      by_cases h : A_d ( d + 1 ) ( x / w ) ( y / w ) ≥ 0 <;> simp_all +decide [ mul_assoc, mul_div_cancel₀ _ hw.ne' ];
      · rw [ Real.mul_rpow ( by positivity ) ( by positivity ), ← Real.rpow_natCast, ← Real.rpow_mul ( by positivity ), Nat.cast_add_one, mul_inv_cancel₀ ( by positivity ), Real.rpow_one ];
        convert mul_le_mul_of_nonneg_left h_ineq hw.le using 1 ; ring;
        simp +decide [ mul_assoc, mul_comm w, hw.ne' ];
      · exact False.elim <| h.not_le <| by exact add_nonneg ( add_nonneg ( mul_nonneg ( mul_nonneg ( mul_nonneg ( Nat.cast_nonneg _ ) <| sub_nonneg.mpr <| Nat.one_le_cast.mpr <| by linarith ) <| div_nonneg hx hw.le ) <| div_nonneg hy hw.le ) <| mul_nonneg ( Nat.cast_nonneg _ ) <| add_nonneg ( div_nonneg hx hw.le ) <| div_nonneg hy hw.le ) zero_le_one;

