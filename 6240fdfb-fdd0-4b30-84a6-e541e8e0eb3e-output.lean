lemma Sk_convex_new (d : ℕ) (hd : d ≥ 2) (a b : ℝ × ℝ × ℝ) (ha : a ∈ S_d d) (hb : b ∈ S_d d) :
    (Real.sqrt (a.1 * b.1), Real.sqrt (a.2.1 * b.2.1), Real.sqrt (a.2.2 * b.2.2)) ∈ S_d d := by
      convert Sk_convex d hd a b ha hb using 1

/-
Derivative of H_func.
-/
noncomputable def H_func (d : ℕ) (x : ℝ) : ℝ := A_d d x x / B_d d x

lemma H_func_deriv (d : ℕ) (hd : d ≥ 1) (x : ℝ) (hx : x ≥ 0) :
    HasDerivAt (H_func d) ((d - 1 : ℝ) + 1 / ((d : ℝ) * x + 1) ^ 2) x := by
      convert HasDerivAt.div ( HasDerivAt.add ( HasDerivAt.const_mul ( ( d : ℝ ) * ( d - 1 ) ) ( hasDerivAt_pow 2 x ) ) ( HasDerivAt.const_mul ( ( d : ℝ ) * 2 ) ( hasDerivAt_id x ) ) |> HasDerivAt.add <| hasDerivAt_const _ _ ) ( HasDerivAt.add ( HasDerivAt.const_mul ( ( d : ℝ ) ) ( hasDerivAt_id x ) ) <| hasDerivAt_const _ _ ) _ using 1 <;> norm_num;
      rotate_left;
      rotate_left;
      exact 1;
      exact 1;
      · positivity;
      · ext; norm_num; ring;
        unfold H_func; ring;
        unfold A_d B_d; ring;
      · rw [ inv_eq_one_div, add_div' ] <;> ring ; positivity

/-
Strict monotonicity of H_func.
-/
lemma H_func_strict_mono (d : ℕ) (hd : d ≥ 1) : StrictMonoOn (H_func d) (Set.Ici 0) := by
  -- The derivative of $H_d(x)$ is $(d-1) + \frac{1}{(dx+1)^2}$.
  have h_H_deriv : ∀ x : ℝ, x ≥ 0 → HasDerivAt (H_func d) ((d - 1 : ℝ) + 1 / ((d : ℝ) * x + 1) ^ 2) x := by
    exact?;
  apply_rules [ strictMonoOn_of_deriv_pos, h_H_deriv ];
  · exact convex_Ici 0;
  · exact continuousOn_of_forall_continuousAt fun x hx => HasDerivAt.continuousAt ( h_H_deriv x hx );
  · norm_num +zetaDelta at *;
    exact fun x hx => HasDerivAt.deriv ( h_H_deriv x hx.le ) ▸ by exact add_pos_of_nonneg_of_pos ( sub_nonneg.mpr ( Nat.one_le_cast.mpr hd ) ) ( inv_pos.mpr ( sq_pos_of_pos ( by positivity ) ) ) ;

/-
H_func is at least 1.
-/
lemma H_func_ge_one (d : ℕ) (hd : d ≥ 1) (x : ℝ) (hx : x ≥ 0) : H_func d x ≥ 1 := by
  exact le_trans ( by norm_num [ H_func, A_d, B_d ] ) ( H_func_strict_mono d hd |> fun h => h.le_iff_le ( by norm_num ) ( by norm_num ; positivity ) |>.2 hx )

/-
Inequality for H_func.
-/
lemma H_func_ineq (d : ℕ) (hd : d ≥ 1) (x s : ℝ) (hx : x ≥ 0) (hs : s ≥ 1)
    (h_eq : H_func d x = s ^ d) :
    H_func (d + 1) (s * x) ≥ s ^ (d + 1) := by
      -- Let $Q(x)$ be the numerator of the combined fraction over $((d+1)s+d)x+1$.
      set Q : ℝ → ℝ := fun x => 2 * s * d * x^2 + (2 * s + d - s^2 * d - s^2) * x - (s - 1);
      -- We need to show that $Q(x) \ge 0$ for $x \ge s-1$.
      have hQ_nonneg : ∀ x, x ≥ s - 1 → Q x ≥ 0 := by
        -- We need to show that $Q(s-1) \ge 0$.
        have hQ_s_minus_1 : Q (s - 1) ≥ 0 := by
          nlinarith [ show ( d : ℝ ) ≥ 1 by norm_cast, mul_le_mul_of_nonneg_left hs <| show 0 ≤ ( d : ℝ ) * ( s - 1 ) by exact mul_nonneg ( Nat.cast_nonneg _ ) <| sub_nonneg.mpr hs, mul_le_mul_of_nonneg_left hs <| show 0 ≤ ( d : ℝ ) * ( s - 1 ) ^ 2 by exact mul_nonneg ( Nat.cast_nonneg _ ) <| sq_nonneg _ ];
        -- Since $Q(x)$ is a quadratic function with a positive leading coefficient, it is increasing for $x \ge s-1$.
        have hQ_incr : ∀ x ≥ s - 1, deriv Q x ≥ 0 := by
          norm_num [ Q, mul_comm ];
          intro x hx; nlinarith [ show ( d : ℝ ) ≥ 1 by norm_cast, show ( s : ℝ ) ≥ 1 by norm_cast, mul_le_mul_of_nonneg_left hs ( show ( d : ℝ ) ≥ 0 by positivity ), mul_le_mul_of_nonneg_left hx ( show ( d : ℝ ) ≥ 0 by positivity ), sq_nonneg ( s - 1 ) ] ;
        intro x hx; by_contra h_neg; push_neg at h_neg; (
        -- Apply the Mean Value Theorem to Q on the interval [s-1, x].
        obtain ⟨c, hc⟩ : ∃ c ∈ Set.Ioo (s - 1) x, deriv Q c = (Q x - Q (s - 1)) / (x - (s - 1)) := by
          apply_rules [ exists_deriv_eq_slope ];
          · exact hx.lt_of_ne ( by rintro rfl; linarith );
          · fun_prop;
          · fun_prop;
        rw [ eq_div_iff ] at hc <;> nlinarith [ hc.1.1, hc.1.2, hQ_incr c hc.1.1.le ]);
      -- By definition of $H_func$, we know that $H_func (d + 1) (s * x) \geq s^{d + 1}$ if and only if $Q(x) \geq 0$.
      have hH_ge_s_pow : H_func (d + 1) (s * x) - s ^ (d + 1) ≥ (Q x) / (((d + 1) * s + d) * x + 1) := by
        -- Substitute the expression for $H_func (d + 1) (s * x) - s^{d + 1}$ from the provided solution.
        have h_subst : H_func (d + 1) (s * x) - s ^ (d + 1) = (1 - s) + s * x + s * x * ((d - (d + 1) * s) * x) / (((d + 1) * s * x + 1) * (d * x + 1)) := by
          unfold H_func;
          unfold A_d B_d; ring;
          field_simp;
          unfold H_func at h_eq; rw [ div_eq_iff ] at h_eq <;> norm_num [ A_d, B_d ] at * <;> try nlinarith;
          grind;
        -- Since $((d+1)sx+1)(dx+1) \ge ((d+1)s+d)x + 1$, we have $s * x * ((d - (d + 1) * s) * x) / (((d + 1) * s * x + 1) * (d * x + 1)) \ge s * x * ((d - (d + 1) * s) * x) / (((d + 1) * s + d) * x + 1)$.
        have h_frac_ge : s * x * ((d - (d + 1) * s) * x) / (((d + 1) * s * x + 1) * (d * x + 1)) ≥ s * x * ((d - (d + 1) * s) * x) / (((d + 1) * s + d) * x + 1) := by
          by_cases h_case : (d - (d + 1) * s) * x ≤ 0;
          · rw [ ge_iff_le, div_le_div_iff₀ ] <;> try positivity;
            exact mul_le_mul_of_nonpos_left ( by nlinarith [ show ( d : ℝ ) * x ≥ 0 by positivity, show ( d : ℝ ) * s * x ≥ 0 by positivity, show ( d : ℝ ) * s ≥ 0 by positivity, show ( d : ℝ ) ≥ 1 by norm_cast, show ( s : ℝ ) ≥ 1 by norm_cast, sq_nonneg ( x * ( d : ℝ ) ), sq_nonneg ( x * ( d + 1 : ℝ ) ), sq_nonneg ( s * ( d : ℝ ) ), sq_nonneg ( s * ( d + 1 : ℝ ) ) ] ) ( by nlinarith [ show ( d : ℝ ) * x ≥ 0 by positivity, show ( d : ℝ ) * s * x ≥ 0 by positivity, show ( d : ℝ ) * s ≥ 0 by positivity, show ( d : ℝ ) ≥ 1 by norm_cast, show ( s : ℝ ) ≥ 1 by norm_cast, sq_nonneg ( x * ( d : ℝ ) ), sq_nonneg ( x * ( d + 1 : ℝ ) ), sq_nonneg ( s * ( d : ℝ ) ), sq_nonneg ( s * ( d + 1 : ℝ ) ) ] );
          · exact False.elim <| h_case <| mul_nonpos_of_nonpos_of_nonneg ( sub_nonpos_of_le <| by nlinarith [ show ( d : ℝ ) ≥ 1 by norm_cast ] ) hx;
        simp +zetaDelta at *;
        convert add_le_add_left h_frac_ge ( 1 - s + s * x ) using 1 ; ring;
        nlinarith [ inv_mul_cancel_left₀ ( by positivity : ( 1 + s * d * x + s * x + d * x ) ≠ 0 ) s, inv_mul_cancel_left₀ ( by positivity : ( 1 + s * d * x + s * x + d * x ) ≠ 0 ) x, inv_mul_cancel₀ ( by positivity : ( 1 + s * d * x + s * x + d * x ) ≠ 0 ) ];
      -- Since $x \geq s - 1$, we can apply $hQ_nonneg$ to conclude that $Q(x) \geq 0$.
      have hx_ge_s_minus_1 : x ≥ s - 1 := by
        -- By Bernoulli's inequality, we have $(1 + (s-1))^d \geq 1 + d(s-1)$.
        have h_bernoulli : (1 + (s - 1)) ^ d ≥ 1 + d * (s - 1) := by
          exact one_add_mul_le_pow ( by linarith ) _ |> le_trans ( by norm_num );
        -- By definition of $H_func$, we know that $H_func d x = s^d$ implies $s^d \leq 1 + d*x$.
        have h_s_d_le : s ^ d ≤ 1 + d * x := by
          unfold H_func at h_eq;
          unfold A_d B_d at h_eq;
          rw [ ← h_eq, div_le_iff₀ ] <;> nlinarith [ show ( d : ℝ ) ≥ 1 by norm_cast, mul_nonneg ( Nat.cast_nonneg d ) hx ];
        norm_num at * ; nlinarith [ ( by norm_cast : ( 1 :ℝ ) ≤ d ) ];
      exact le_of_sub_nonneg ( hH_ge_s_pow.trans' ( div_nonneg ( hQ_nonneg x hx_ge_s_minus_1 ) ( by positivity ) ) )

/-
Definition of x_func using epsilon.
-/
noncomputable def x_func (d : ℕ) (s : ℝ) : ℝ :=
  Classical.epsilon (fun x => x ≥ 0 ∧ H_func d x = s ^ d)

/-
Limit of H_func at infinity.
-/
lemma H_func_tendsto_atTop (d : ℕ) (hd : d ≥ 2) :
    Filter.Tendsto (H_func d) Filter.atTop Filter.atTop := by
      -- We can simplify the expression for H_func d x as x approaches infinity.
      have h_simplify : Filter.Tendsto (fun x : ℝ => (d * (d - 1) * x ^ 2 + 2 * d * x + 1) / (d * x + 1)) Filter.atTop Filter.atTop := by
        refine' Filter.tendsto_atTop_atTop.mpr fun x => _;
        exact ⟨ Max.max x 1, fun a ha => by rw [ le_div_iff₀ ] <;> nlinarith [ le_max_left x 1, le_max_right x 1, show ( d : ℝ ) ≥ 2 by norm_cast, mul_le_mul_of_nonneg_left ( show ( d : ℝ ) ≥ 2 by norm_cast ) ( by linarith [ le_max_left x 1, le_max_right x 1 ] : ( 0 : ℝ ) ≤ a ) ] ⟩;
      convert h_simplify using 2 ; unfold H_func ; unfold A_d B_d ; ring

/-
Value of H_func at 0.
-/
lemma H_func_zero (d : ℕ) : H_func d 0 = 1 := by
  unfold H_func A_d B_d; norm_num;

/-
Property of x_func for d >= 2.
-/
lemma x_func_spec (d : ℕ) (hd : d ≥ 2) (s : ℝ) (hs : s ≥ 1) :
    x_func d s ≥ 0 ∧ H_func d (x_func d s) = s ^ d := by
      -- By the properties of the intermediate value theorem, since $H_func d$ is continuous on $[0, \infty)$ and $H_func d(0) = 1$, there exists $x \geq 0$ such that $H_func d(x) = s^d$.
      have h_ivt : ∃ x ∈ Set.Ici 0, H_func d x = s ^ d := by
        have h_cont : ContinuousOn (H_func d) (Set.Ici 0) := by
          refine' ContinuousOn.div _ _ _;
          · exact Continuous.continuousOn ( by unfold A_d; continuity );
          · exact Continuous.continuousOn ( by unfold B_d; continuity );
          · exact fun x hx => ne_of_gt <| add_pos_of_nonneg_of_pos ( mul_nonneg ( Nat.cast_nonneg _ ) hx ) zero_lt_one
        have h_lim : Filter.Tendsto (H_func d) Filter.atTop Filter.atTop := by
          convert H_func_tendsto_atTop d hd using 1
        have h_ivt : ∃ x ∈ Set.Ici 0, H_func d x ≥ s ^ d := by
          exact Filter.Eventually.and ( Filter.eventually_ge_atTop 0 ) ( h_lim.eventually_ge_atTop _ ) |> fun h => h.exists;
        have h_ivt : ∃ x ∈ Set.Icc 0 (h_ivt.choose), H_func d x = s ^ d := by
          apply_rules [ intermediate_value_Icc ];
          · exact h_ivt.choose_spec.1;
          · exact h_cont.mono <| Set.Icc_subset_Ici_self;
          · exact ⟨ by rw [ H_func_zero ] ; exact one_le_pow₀ hs, h_ivt.choose_spec.2 ⟩;
        exact ⟨ h_ivt.choose, h_ivt.choose_spec.1.1, h_ivt.choose_spec.2 ⟩;
      exact Classical.epsilon_spec h_ivt |> fun h => ⟨ h.1, h.2 ⟩

/-
Definition of Phi_func.
-/
noncomputable def Phi_func (d : ℕ) (s : ℝ) : ℝ :=
  (B_d d (x_func d s)) ^ (1 / (d : ℝ)) / (A_d (d + 1) (x_func d s) (x_func d s)) ^ (1 / ((d : ℝ) + 1))
