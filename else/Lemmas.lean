open SimpleGraph Finset BigOperators

variable {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj]

def SimpleGraph.indepSets : Finset (Finset V) :=
  univ.filter (fun s => G.IsIndepSet s)

/-
