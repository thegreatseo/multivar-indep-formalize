    (lambda : V → ℝ) (mu : V → ℝ) : ℝ :=
  ∑ I ∈ G.indepSets, ∑ J ∈ G.indepSets, if Disjoint I J then (∏ v ∈ I, lambda v) * (∏ u ∈ J, mu u) else 0

