        intro a ha x hx hx' hx'' y hy hy' hy'' hxy; have := ha hx'' hy''; simp_all +decide [ SimpleGraph.adj_comm ] ;
      · simp +decide [ Finset.ext_iff, Set.ext_iff ];
        intro a₁ ha₁ a₂ ha₂ h a ha₁' ha₂'; specialize h a; aesop;
      · intro b hb hv
        use Finset.filter (fun x => x.val ∈ b ∧ x.val ≠ v ∧ ¬G.Adj v x.val) (Finset.univ : Finset { x : V // ¬x = v ∧ ¬G.Adj v x });
        refine' ⟨ _, _ ⟩;
        · simp +decide [ indepSets, SimpleGraph.IsIndepSet ];
          intro x hx y hy hxy; have := hb ( show ( x : V ) ∈ b from by aesop ) ( show ( y : V ) ∈ b from by aesop ) ; aesop;
        · ext x; by_cases hx : x = v <;> simp +decide [ hx, hv ] ;
          exact fun hx' => hb hv hx' |> fun h => by tauto;

/-
The term $(1+(d+1)w)^{1/(d+1)}$ is non-increasing in $d$.
-/
lemma term_monotonicity (d d' : ℕ) (w : ℝ) (hw : 0 ≤ w) (h : d ≤ d') :
    (1 + (d + 1 : ℝ) * w) ^ (1 / (d + 1 : ℝ)) ≥ (1 + (d' + 1 : ℝ) * w) ^ (1 / (d' + 1 : ℝ)) := by
  -- Let $f(x) = (1+xw)^{1/x}$. We show $f(x)$ is decreasing for $x > 0$.
  have h_decreasing : ∀ x y : ℝ, 0 < x → x < y → (1 + x * w) ^ (1 / x : ℝ) ≥ (1 + y * w) ^ (1 / y : ℝ) := by
    -- Taking the natural logarithm of both sides, we need to show that $\frac{\ln(1+yw)}{y} \leq \frac{\ln(1+xw)}{x}$ for $0 < x < y$.
    suffices h_ln : ∀ x y : ℝ, 0 < x → x < y → Real.log (1 + y * w) / y ≤ Real.log (1 + x * w) / x by
      exact fun x y hx hy => by rw [ Real.rpow_def_of_pos ( by nlinarith ), Real.rpow_def_of_pos ( by nlinarith ) ] ; simpa [ div_eq_mul_inv ] using Real.exp_le_exp.mpr ( h_ln x y hx hy ) ;
    -- Let's consider the function $f(x) = \frac{\ln(1 + xw)}{x}$ and show that it is decreasing for $x > 0$.
    have h_decreasing : ∀ x y : ℝ, 0 < x → x < y → deriv (fun x => Real.log (1 + x * w) / x) x ≤ 0 := by
      intro x y hx hy; norm_num [ show 1 + x * w ≠ 0 by nlinarith, hx.ne' ] ; ring_nf; norm_num; (
                                    exact mul_le_mul_of_nonneg_right ( by nlinarith [ inv_mul_cancel_left₀ ( by nlinarith : ( 1 + w * x ) ≠ 0 ) ( w * x ), Real.log_inv ( 1 + w * x ), Real.log_le_sub_one_of_pos ( inv_pos.mpr ( by nlinarith : 0 < 1 + w * x ) ), mul_inv_cancel₀ ( by nlinarith : ( 1 + w * x ) ≠ 0 ) ] ) ( by positivity ));
    -- By the Mean Value Theorem, there exists some $c \in (x, y)$ such that $f'(c) = \frac{f(y) - f(x)}{y - x}$.
    intros x y hx hy
    obtain ⟨c, hc⟩ : ∃ c ∈ Set.Ioo x y, deriv (fun x => Real.log (1 + x * w) / x) c = (Real.log (1 + y * w) / y - Real.log (1 + x * w) / x) / (y - x) := by
      apply_rules [ exists_deriv_eq_slope ];
      · exact continuousOn_of_forall_continuousAt fun x hx => ContinuousAt.div ( ContinuousAt.log ( continuousAt_const.add ( continuousAt_id.mul continuousAt_const ) ) ( by nlinarith [ hx.1 ] ) ) continuousAt_id ( by linarith [ hx.1 ] );
      · exact DifferentiableOn.div ( DifferentiableOn.log ( DifferentiableOn.add ( differentiableOn_const _ ) ( differentiableOn_id.mul_const _ ) ) ( by intro u hu; nlinarith [ hu.1 ] ) ) differentiableOn_id ( by intro u hu; linarith [ hu.1 ] );
    have := h_decreasing c y ( by linarith [ hc.1.1 ] ) hc.1.2; rw [ hc.2, div_le_iff₀ ] at this <;> linarith;
  cases eq_or_lt_of_le h <;> [ aesop; exact h_decreasing _ _ ( by positivity ) ( by norm_cast; linarith ) ]

/-
A version of `key_tech_ineq` for `Finset`s.
-/
lemma key_tech_ineq_finset {V : Type*} [DecidableEq V] (S : Finset V) (n : ℕ) (hn : S.card = n) (hn_ge_1 : n ≥ 1)
    (d : V → ℕ) (hd : ∀ i ∈ S, 1 ≤ d i ∧ d i ≤ n)
    (w : V → ℝ) (hw : ∀ i ∈ S, 0 ≤ w i) (w0 : ℝ) (hw0 : 0 ≤ w0) :
    ∏ i ∈ S, (1 + (d i : ℝ) * w i) ^ (1 / (d i : ℝ)) + w0 ≥
    ((n + 1 : ℝ) * w0 + 1) ^ (1 / (n + 1 : ℝ)) * ∏ i ∈ S, (1 + ((d i : ℝ) + 1) * w i) ^ (1 / ((d i : ℝ) + 1)) := by
  -- Let $e : Fin n ≃ S$ be an equivalence.
  obtain ⟨e, he⟩ : ∃ e : Fin n ≃ S, True := by
    exact ⟨ ( Fintype.equivOfCardEq <| by simp +decide [ hn ] ), trivial ⟩;
  convert key_tech_ineq n hn_ge_1 ( fun i => d ( e i ) ) ( fun i => ?_ ) ( fun i => w ( e i ) ) ( fun i => ?_ ) w0 hw0 using 1;
  · rw [ ← Finset.prod_coe_sort ];
    conv_lhs => rw [ ← Equiv.prod_comp e ] ;
  · refine' congr rfl ( Finset.prod_bij ( fun i hi => Classical.choose ( e.surjective ⟨ i, hi ⟩ ) ) _ _ _ _ ) <;> simp +decide [ Classical.choose_spec ( e.surjective _ ) ];
    · intro a₁ ha₁ a₂ ha₂ h; have := Classical.choose_spec ( e.surjective ⟨ a₁, ha₁ ⟩ ) ; have := Classical.choose_spec ( e.surjective ⟨ a₂, ha₂ ⟩ ) ; aesop;
    · intro b; use e b; have := Classical.choose_spec ( e.surjective ( e b ) ) ; aesop;
  · exact hd _ ( e i |>.2 );
  · exact hw _ ( e i |>.2 )

/-
Definition of the lower bound term for the independence polynomial.
-/
noncomputable def indepPolyLowerBound {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj] (w : V → ℝ) : ℝ :=
  ∏ v : V, ((G.degree v + 1 : ℝ) * w v + 1) ^ (1 / (G.degree v + 1 : ℝ))

/-
The degree of a vertex u in G - {v} is deg(u) - 1 if u is adjacent to v, and deg(u) otherwise.
-/
lemma degree_delete_eq {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj] (v : V) (u : V) (h : u ≠ v) :
    (G.induce {x | x ≠ v}).degree ⟨u, h⟩ = if G.Adj v u then G.degree u - 1 else G.degree u := by
  simp +decide [ SimpleGraph.degree, SimpleGraph.neighborFinset_def ];
  split_ifs with h';
  · rw [ ← Finset.card_erase_of_mem ( Finset.mem_filter.mpr ⟨ Finset.mem_univ _, h'.symm ⟩ ) ];
    refine' Finset.card_bij ( fun x hx => x ) _ _ _ <;> aesop;
  · rw [ Finset.card_filter, Finset.card_filter ];
    rw [ ← Finset.sum_subset ( Finset.subset_univ ( Finset.image ( fun x : { x : V // ¬x = v } => ( x : V ) ) Finset.univ ) ) ];
    · rw [ Finset.sum_image ] ; aesop;
    · simp +contextual;
      rwa [ SimpleGraph.adj_comm ]

/-
The degree of a vertex in an induced subgraph is at most its degree in the original graph.
-/
lemma degree_induce_le {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj] (s : Set V) [DecidablePred (· ∈ s)] (v : s) :
    (G.induce s).degree v ≤ G.degree v := by
  simp +decide [ SimpleGraph.degree, SimpleGraph.neighborFinset ];
  convert Set.ncard_le_ncard ( show ( Set.image ( fun x : s => x.val ) ( { x : s | G.Adj v x } ) ) ⊆ ( Set.image ( fun x : V => x ) ( { x : V | G.Adj v x } ) ) from ?_ ) using 1 <;> simp +decide [ Set.ncard_eq_toFinset_card' ];
  rw [ Finset.card_image_of_injective _ Subtype.coe_injective ]

/-
The algebraic step for the lower bound proof, applying the key inequality to the neighbors of a max degree vertex.
-/
lemma indep_poly_lower_bound_step {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj]
    (w : V → ℝ) (hw : ∀ v, 0 ≤ w v) (v : V) (h_max : ∀ u, G.degree u ≤ G.degree v) :
    (∏ u ∈ G.neighborFinset v, ((G.degree u : ℝ) * w u + 1) ^ (1 / (G.degree u : ℝ))) + w v ≥
    ((G.degree v + 1 : ℝ) * w v + 1) ^ (1 / (G.degree v + 1 : ℝ)) * ∏ u ∈ G.neighborFinset v, ((G.degree u + 1 : ℝ) * w u + 1) ^ (1 / (G.degree u + 1 : ℝ)) := by
  by_cases hd : G.degree v = 0 <;> simp_all +decide [ SimpleGraph.degree, SimpleGraph.neighborFinset ];
  · simp +decide [ SimpleGraph.neighborSet, h_max ];
    linarith;
  · have := @key_tech_ineq_finset V _ ( G.neighborSet v |> Set.toFinset ) ( Fintype.card ( { x : V | G.Adj v x } ) ) ?_ ?_ ( fun u => Fintype.card ( { x : V | G.Adj u x } ) ) ?_ ( fun u => w u ) ?_ ( w v ) ?_ <;> simp_all +decide [ SimpleGraph.neighborFinset ];
    · convert this using 3 <;> simp +decide [ add_comm, Fintype.card_subtype ];
    · exact?;
    · exact Fintype.card_pos_iff.mpr ⟨ ⟨ hd.choose, hd.choose_spec ⟩ ⟩;
    · simp_all +decide [ Fintype.card_subtype ];
      exact fun u hu => ⟨ v, by simpa [ SimpleGraph.adj_comm ] using hu ⟩

/-
Splitting the lower bound product for $G-v$ into neighbors and non-neighbors.
-/
lemma prod_G_minus_v_eq {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj]
    (w : V → ℝ) (v : V) :
    indepPolyLowerBound (G.induce {x | x ≠ v}) (w ∘ Subtype.val) =
    (∏ u ∈ G.neighborFinset v, ((G.degree u : ℝ) * w u + 1) ^ (1 / (G.degree u : ℝ))) *
    (∏ u ∈ Finset.univ.filter (fun x => x ≠ v ∧ ¬G.Adj v x), ((G.degree u + 1 : ℝ) * w u + 1) ^ (1 / (G.degree u + 1 : ℝ))) := by
  unfold indepPolyLowerBound;
  -- Apply the degree deletion lemma to each term in the product.
  have h_deg_deletion : ∀ u : {x : V | x ≠ v}, ((SimpleGraph.induce {x | x ≠ v} G).degree u + 1 : ℝ) = if G.Adj v u.val then (G.degree u.val : ℝ) else (G.degree u.val + 1 : ℝ) := by
    intro u
    have h_deg : (SimpleGraph.induce {x | x ≠ v} G).degree u = if G.Adj v u.val then G.degree u.val - 1 else G.degree u.val := by
      convert degree_delete_eq G v u.val u.prop using 1;
    split_ifs at * <;> simp_all +decide;
    rw [ Nat.cast_sub ] <;> norm_num ; exact G.degree_pos_iff_exists_adj _ |>.2 ⟨ v, by tauto ⟩;
  simp_all +decide [ Finset.prod_ite, Finset.filter_congr ];
  rw [ ← Finset.prod_filter_mul_prod_filter_not ( Finset.univ : Finset { x : V // ¬x = v } ) fun x => G.Adj v x ];
  refine' congrArg₂ _ _ _;
  · refine' Finset.prod_bij ( fun x hx => x ) _ _ _ _ <;> aesop;
  · refine' Finset.prod_bij ( fun x hx => x ) _ _ _ _ <;> aesop
