      refine' Finset.sum_bij ( fun I hI => Insert.insert v ( Finset.image ( fun x : { x // ¬x = v ∧ ¬G.Adj v x } => x.val ) I ) ) _ _ _ _ <;> simp +decide [ Finset.prod_insert, Finset.mem_image ];
      · simp +decide [ SimpleGraph.IsIndepSet, Set.Pairwise ];
        simp +decide [ indepSets, SimpleGraph.IsIndepSet ];
