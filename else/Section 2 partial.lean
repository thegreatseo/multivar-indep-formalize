        refine' ⟨ ⟨ I.image Subtype.val, _ ⟩, _ ⟩ <;> simp_all +decide [ Set.Pairwise, Set.ext_iff ];
      · simp +contextual [ Finset.ext_iff, Set.ext_iff ];
        intro a₁ ha₁ a₂ ha₂ h a ha; specialize h a; aesop;
      · intro a ha hv
        refine' ⟨ Finset.filter ( fun x => x.val ∈ a ) Finset.univ, _, _ ⟩
        · simp +decide [ indepSets, SimpleGraph.IsIndepSet, Finset.mem_filter ]
          intro x hx y hy hxy
          have hx_in_a : x.val ∈ a := by aesop
          have hy_in_a : y.val ∈ a := by aesop
          have hxney: x.val ≠ y.val := by aesop
