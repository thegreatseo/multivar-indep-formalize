  simp +decide [ multivariateIndependencePolynomial ];
  -- Let's simplify the sum over the independent sets of the induced graph.
  have h_ind : ∑ I ∈ Finset.filter (fun I => G.IsIndepSet I) (Finset.powerset (Finset.univ : Finset V)), (∏ v ∈ I, w v) =
    (∑ I ∈ Finset.filter (fun I => G.IsIndepSet I ∧ v ∉ I) (Finset.powerset (Finset.univ : Finset V)), (∏ v ∈ I, w v)) +
    (∑ I ∈ Finset.filter (fun I => G.IsIndepSet I ∧ v ∈ I) (Finset.powerset (Finset.univ : Finset V)), (∏ v ∈ I, w v)) := by
      rw [ ← Finset.sum_union ];
      · congr with I ; by_cases hv : v ∈ I <;> aesop;
      · exact Finset.disjoint_filter.mpr ( by aesop );
  convert h_ind using 1;
  · refine' Finset.sum_bij ( fun I _ => I ) _ _ _ _ <;> simp +decide;
    · exact fun I hI => Finset.mem_filter.mp hI |>.2;
    · exact fun a ha => Finset.mem_filter.mpr ⟨ Finset.mem_powerset.mpr ( Finset.subset_univ _ ), ha ⟩;
