/-
The set of all independent sets of a graph G.
-/
def indepSets {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj] : Finset (Finset V) :=
  Finset.univ.powerset.filter (fun s => G.IsIndepSet s)

/-
The multivariate independence polynomial of a graph G with weights w.
-/
noncomputable def multivariateIndependencePolynomial {V : Type*} [Fintype V] [DecidableEq V] (G : SimpleGraph V) [DecidableRel G.Adj] {R : Type*} [CommSemiring R] (w : V → R) : R :=
  ∑ I ∈ indepSets G, ∏ v ∈ I, w v

